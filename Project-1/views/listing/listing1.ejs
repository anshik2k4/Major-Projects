
<% layout("/layouts/boiler.ejs")%> 

<%- include("../includes/category-bar.ejs") %>

    <% 
      const titles = {
        beach: "Beachside stays",
        mountain: "Mountain getaways",
        city: "City stays",
        countryside: "Countryside retreats",
        lake: "Lakeside stays",
        camping: "Camping & outdoors",
        luxury: "Luxury stays",
      };
      const listSearchQ = (typeof locals !== "undefined" && locals.searchQuery !== undefined)
        ? String(locals.searchQuery || "").trim()
        : (typeof searchQuery !== "undefined" ? String(searchQuery || "").trim() : "");
      const listCat = (typeof locals !== "undefined" && locals.selectedCategory != null)
        ? locals.selectedCategory
        : (typeof selectedCategory !== "undefined" ? selectedCategory : null);
      const hasSearch = !!listSearchQ;
      let pageTitle = "All listings";
      if (hasSearch) {
        pageTitle = "Search results";
      } else if (listCat && titles[listCat]) {
        pageTitle = titles[listCat];
      }
    %>
    <h1 class="list-title"><%= pageTitle %></h1>
    <% if (hasSearch) { %>
      <p class="list-search-sub text-muted text-center mb-3">Showing results for &ldquo;<%= listSearchQ %>&rdquo;</p>
    <% } %>

    <div class="container px-lg-5 px-md-3  px-2 ">
  <ul class="row  g-3 justify-content-between">

  <% for(let listing of alllisting){ %>
    <li class="col listing-style">
        <a href="/listing/<%=listing._id%>" class="text-decoration-none text-reset ">

             <div class="card shadow-sm" style="width: 15rem;">
  <!-- listing1.ejs -->
<img src="<%= typeof listing.image === 'object' ? listing.image.url : listing.image %>" class="card-img-top imaging" alt="...">

  <div class="card-body">
    <h5 class="card-title fw-bold small"><%=listing.title%></h5>
    <h3 class="card-title text-muted mb-2"><%=listing.location%></h3>
    <p><b class="fs-2">₹</b> <b class="fs-3"><%=listing.price.toLocaleString("en-IN")%></b>/night</p>
  </div>
</div>

        </a>
      
   </li>
    <%} %>
    </ul>

    <% if (alllisting.length === 0) { %>
      <p class="text-center text-muted py-5 mb-0">
        <% if (hasSearch) { %>
          No stays match your search. Try different words or clear the search box.
        <% } else { %>
          No stays in this category yet. Try another type or add a new listing.
        <% } %>
      </p>
    <% } %>
    
    </div>
  