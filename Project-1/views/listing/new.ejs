<% layout("/layouts/boiler.ejs")%>
<body>
    <div class="container py-5">
        <div class="unique-form-container shadow-lg">
            <h2 class="form-title">Create New Stay</h2>
            
            <form action="/listing" method="POST" novalidate class="needs-validation">

  <!-- Title -->
  <input type="text" class="unique-input" name="title"
         placeholder="🏠 Listing Title" required>
  <div class="invalid-feedback form-feedback">
    Title cannot be empty.
  </div>
  <div class="valid-feedback form-feedback">
    Looks good! Nice title.
  </div>

  <!-- Description -->
   <div>

    <textarea class="unique-input unique-textarea" name="description" placeholder="✍️ Description of your stay..." required></textarea>
  <div class="invalid-feedback form-feedback">
    Please enter a shorter description.
  </div>
  <div class="valid-feedback form-feedback">
    Description looks good.
  </div>

   </div>
  

  <!-- Image URL (optional) -->
  <input type="url" class="unique-input" name="imageurl"
         placeholder="🖼️ Image URL">

  <div class="input row">
    <div class="col-md-4">
      <input type="number" class="unique-input" name="price"
             placeholder="💰 Price" required>
      <div class="invalid-feedback form-feedback">
        Price is required.
      </div>
      <div class="valid-feedback form-feedback">
        Price set!
      </div>
    </div>

    <div class="col-md-6">
      <input type="text" class="unique-input" name="country"
             placeholder="🌍 Country" required>
      <div class="invalid-feedback form-feedback">
        Country is required.
      </div>
      <div class="valid-feedback form-feedback">
        Country looks good.
      </div>
    </div>
  </div>

  <div>
     
     <input type="text" class="unique-input" name="location"
       placeholder="📍 Location" required>
<div class="invalid-feedback form-feedback">
  Location is required.
</div>
<div class="valid-feedback form-feedback">
  Location looks good.
</div>


  </div>


  <div class="row justify-content-center mt-4">
    <div class="col-5 col-md-4 col-lg-3">
      <button type="submit" class="btn btn-outline-danger w-100 py-3">
        Publish Listing
      </button>
    </div>
  </div>
</form>

        </div>
    </div>
</body>