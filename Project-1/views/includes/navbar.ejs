<%
  const navSearch = (typeof locals !== 'undefined' && locals.searchQuery !== undefined) ? locals.searchQuery : '';
%>
<nav class="navbar navbar-expand-lg navbar-light stayhub-navbar">
  <div class="container-fluid px-3 px-lg-4">
    <div class="d-flex align-items-center flex-shrink-0 gap-2 gap-md-3">
      <a class="navbar-brand stayhub-brand fw-bold mb-0 d-inline-flex align-items-center gap-2" href="/listing">
        <img src="/images/stayhub-icon.svg" alt="" class="stayhub-logo-mark" width="40" height="40" decoding="async">
        <span class="stayhub-wordmark">StayHub</span>
      </a>
      <% if (isLoggedIn) { %>
        <a class="btn btn-add-stay d-inline-flex align-items-center" href="/listing/new" title="Add a new listing">
          <i class="fas fa-plus-circle btn-add-stay__icon" aria-hidden="true"></i>
          <span class="btn-add-stay__text">Add your Stay</span>
        </a>
      <% } %>
    </div>

    <button class="navbar-toggler stayhub-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse mt-3 mt-lg-0" id="navbarNav">
      <form class="navbar-search-form mx-lg-auto my-2 my-lg-0" method="GET" action="/listing" role="search" aria-label="Search stays">
        <div class="input-group navbar-search-input-group">
          <input type="search" name="q" class="form-control navbar-search-field" placeholder="Search by place, title…" value="<%= navSearch %>" autocomplete="off" maxlength="120" aria-label="Search listings">
          <button class="btn btn-search-submit" type="submit" aria-label="Search">
            <i class="fas fa-search me-md-1" aria-hidden="true"></i>
            <span class="d-none d-md-inline">Search</span>
          </button>
        </div>
      </form>

      <ul class="navbar-nav stayhub-nav-actions ms-lg-3 align-items-center gap-lg-1 pt-2 pt-lg-0 border-top border-lg-0 mt-2 mt-lg-0">
        <% if (isLoggedIn) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle stayhub-nav-user fw-semibold" href="#" data-bs-toggle="dropdown" aria-expanded="false">
              <i class="fas fa-user-circle me-1" aria-hidden="true"></i><%= currentUser.username %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
              <li>
                <a href="/logout" class="dropdown-item fw-semibold text-danger">
                  <i class="fas fa-sign-out-alt me-2" aria-hidden="true"></i>Logout
                </a>
              </li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a href="/login" class="btn btn-outline-danger stayhub-auth-btn px-3 py-2 pstion">
              <i class="fas fa-sign-in-alt me-1" aria-hidden="true"></i>Login
            </a>
          </li>
         <li class="nav-item ms-2">
            <a href="/signup" class="btn btn-danger stayhub-auth-btn px-3 py-2">
              <i class="fas fa-user-plus me-1" aria-hidden="true"></i>Signup
            </a>
          </li>
        <% } %>
        <li class="nav-item">
          <button type="button" class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
            <i class="fas fa-moon" aria-hidden="true"></i>
          </button>
        </li>
      </ul>
    </div>
  </div>
</nav>
